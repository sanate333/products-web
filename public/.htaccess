# ГўВ”ВЂГўВ”ВЂ Disable LiteSpeed Cache GLOBALLY ГўВ”ВЂГўВ”ВЂ
<IfModule LiteSpeed>
CacheLookup off
</IfModule>

# ГўВ”ВЂГўВ”ВЂ No-cache headers for HTML, JS, CSS, JSON ГўВ”ВЂГўВ”ВЂ
<IfModule mod_headers.c>
<FilesMatch "\.(html|js|css|json)$">
Header set Cache-Control "no-cache, no-store, must-revalidate"
Header set Pragma "no-cache"
Header set Expires "0"
</FilesMatch>
</IfModule>

DirectoryIndex home.html index.html index.php
RewriteEngine On
RewriteBase /

# ГўВ”ВЂГўВ”ВЂ API Routes ГўВ”ВЂГўВ”ВЂ
RewriteRule ^api/ops/notifications/campaigns/?$ apiOpsNotificationsCampaigns.php [L,QSA]
RewriteRule ^api/ops/notifications/campaigns/([0-9]+)/send/?$ apiOpsNotificationsCampaignSend.php?id=$1 [L,QSA]
RewriteRule ^api/ops/notifications/campaigns/([0-9]+)/deliveries/?$ apiOpsNotificationsCampaignDeliveries.php?id=$1 [L,QSA]
RewriteRule ^api/ops/notifications/run-automations/?$ apiOpsNotificationsRunAutomations.php [L,QSA]
RewriteRule ^api/store/notifications/?$ apiStoreNotifications.php [L,QSA]
RewriteRule ^api/store/notifications/unread-count/?$ apiStoreNotificationsUnreadCount.php [L,QSA]
RewriteRule ^api/store/notifications/([0-9]+)/read/?$ apiStoreNotificationRead.php?deliveryId=$1 [L,QSA]
RewriteRule ^api/ops/dropshipping/templates/?$ apiOpsDropshippingTemplates.php [L,QSA]
RewriteRule ^api/ops/dropshipping/catalog/?$ apiOpsDropshippingCatalog.php [L,QSA]
RewriteRule ^api/ops/dropshipping/stores/?$ apiOpsDropshippingStores.php [L,QSA]
RewriteRule ^api/ops/dropshipping/store-products/?$ apiOpsDropshippingStoreProducts.php [L,QSA]
RewriteRule ^api/ops/dropshipping/sync-store-products/?$ apiOpsDropshippingSyncStoreProducts.php [L,QSA]
RewriteRule ^api/ops/dropshipping/notify/?$ apiOpsDropshippingNotify.php [L,QSA]
RewriteRule ^api/ops/dropshipping/activity/?$ apiOpsDropshippingActivity.php [L,QSA]
RewriteRule ^api/store/dropshipping/catalog/?$ apiStoreDropshippingCatalog.php [L,QSA]
RewriteRule ^api/store/dropshipping/my-products/?$ apiStoreDropshippingMyProducts.php [L,QSA]
RewriteRule ^api/store/dropshipping/add/?$ apiStoreDropshippingAdd.php [L,QSA]
RewriteRule ^api/store/dropshipping/remove/?$ apiStoreDropshippingRemove.php [L,QSA]
RewriteRule ^api/store/dropshipping/update-margin/?$ apiStoreDropshippingUpdateMargin.php [L,QSA]
RewriteRule ^api/ops/wallet/overview/?$ apiOpsWalletOverview.php [L,QSA]
RewriteRule ^api/ops/wallet/ledger/?$ apiOpsWalletLedger.php [L,QSA]
RewriteRule ^api/ops/orders/?$ apiOpsOrders.php [L,QSA]
RewriteRule ^api/ops/orders/([0-9]+)/?$ apiOpsOrdersPatch.php?id=$1 [L,QSA]
RewriteRule ^api/ops/orders/([0-9]+)/release/?$ apiOpsOrdersRelease.php?id=$1 [L,QSA]
RewriteRule ^api/ops/withdrawals/?$ apiOpsWithdrawals.php [L,QSA]
RewriteRule ^api/ops/withdrawals/([0-9]+)/?$ apiOpsWithdrawalsPatch.php?id=$1 [L,QSA]
RewriteRule ^api/store/wallet/overview/?$ apiStoreWalletOverview.php [L,QSA]
RewriteRule ^api/store/wallet/ledger/?$ apiStoreWalletLedger.php [L,QSA]
RewriteRule ^api/store/wallet/withdrawals/?$ apiStoreWalletWithdrawals.php [L,QSA]
RewriteRule ^api/ai-images/analyze/?$ aiImagesAnalyze.php [L,QSA]
RewriteRule ^api/ai-images/generate/?$ aiImagesGenerate.php [L,QSA]
RewriteRule ^api/ai-images/list/?$ aiImagesList.php [L,QSA]
RewriteRule ^api/ai-images/status/?$ aiImagesStatus.php [L,QSA]
RewriteRule ^api/ai-images/delete/?$ aiImagesDelete.php [L,QSA]
RewriteRule ^api/ai-images/health/?$ aiImagesHealth.php [L,QSA]
RewriteRule ^api/whatsapp/(.*)$ whatsapp-proxy.php?path=$1 [L,QSA]
RewriteRule ^waBackendUrl\.php$ waBackendUrl.php [L,QSA]
RewriteRule ^api/co/register/?$ api/co/register/index.php [L,QSA]
RewriteRule ^api/co/leads/?$ api/co/leads/index.php [L,QSA]
RewriteRule ^co/?$ /index.html [L]

# ГўВ”ВЂГўВ”ВЂ Static files: serve directly, DO NOT pass to SPA ГўВ”ВЂГўВ”ВЂ
RewriteRule ^home\.html$ - [L]
RewriteRule ^proveedores\.html$ - [L]

# Home Plus V5 FINAL
RewriteRule ^$ /home.html [L]
# Home Free React
RewriteRule ^home-free/?$ /index.html [L]
# Portal proveedores
RewriteRule ^proveedores/?$ /proveedores.html [L]
# Dashboard pedidos
RewriteRule ^dashboard/?$ /dashboard.html [L]

# SPA catch-all ГўВЂВ” only if file does NOT exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]

php_value upload_max_filesize 20M
php_value post_max_size 20M
php_value max_file_uploads 50
php_value max_execution_time 120
